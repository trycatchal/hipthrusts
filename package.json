{
  "name": "hipthrusts",
  "version": "0.11.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/captaincaius/hipthrusts.git"
  },
  "description": "Build stronger, leaner backends with HipThrusTS",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib/**/*.js",
    "lib/**/*.d.ts"
  ],
  "scripts": {
    "clean": "rimraf lib .tsbuildinfo .nyc_output coverage doc build",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.json",
    "lint": "tslint --project tsconfig.base.json",
    "tsc": "tsc",
    "tslint-check": "tslint-config-prettier-check ./tslint.json",
    "prepublishOnly": "pnpm clean && pnpm build",
    "prettier": "if test -z $CI; then prettier --write \"./{src,test}/**/*.{ts,js}\"; fi"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "@hapi/boom": "^9.1.4",
    "express": "^5.1.0",
    "fastify": "^5",
    "hono": "^4",
    "json-mask": "^0.3.8",
    "mongoose": "^6.13.9",
    "next": ">=14",
    "zod": "^4.2.1"
  },
  "peerDependenciesMeta": {
    "@hapi/boom": { "optional": true },
    "express": { "optional": true },
    "fastify": { "optional": true },
    "hono": { "optional": true },
    "json-mask": { "optional": true },
    "mongoose": { "optional": true },
    "next": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@hapi/boom": "^9.1.4",
    "@hono/node-server": "^2.0.1",
    "@types/boom": "^7.3.5",
    "@types/express": "^5.0.6",
    "@types/mongoose": "^5.5.23",
    "@types/node": "^22.19.17",
    "coveralls": "^3.0.6",
    "express": "^5.1.0",
    "fastify": "^5.8.5",
    "hono": "^4.12.17",
    "husky": "^1.3.1",
    "json-mask": "^0.3.8",
    "mongoose": "^6.13.9",
    "next": "^15.5.4",
    "prettier": "^1.18.2",
    "pretty-quick": "^1.10.0",
    "rimraf": "3.0.0",
    "ts-node": "^8.4.1",
    "tslint": "5.20.0",
    "tslint-config-prettier": "^1.18.0",
    "tslint-eslint-rules": "*5.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "zod": "^4.2.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged && pnpm lint && pnpm test"
    }
  },
  "author": "Captain Caius"
}
