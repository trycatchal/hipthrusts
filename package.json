{
  "name": "hipthrusts",
  "version": "0.13.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/trycatchal/hipthrusts.git"
  },
  "description": "Build stronger, leaner backends with HipThrusTS",
  "homepage": "https://github.com/trycatchal/hipthrusts#readme",
  "bugs": {
    "url": "https://github.com/trycatchal/hipthrusts/issues"
  },
  "keywords": [
    "typescript",
    "security",
    "authorization",
    "validation",
    "sanitization",
    "request-handler",
    "express",
    "fastify",
    "hono",
    "nextjs",
    "trpc",
    "mongoose",
    "zod",
    "backend",
    "api"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/commonjs/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "files": [
    "dist"
  ],
  "tshy": {
    "exports": {
      ".": "./src/index.ts",
      "./core": "./src/core.ts",
      "./errors": "./src/errors.ts",
      "./http-adapter": "./src/http-adapter.ts",
      "./lifecycle-functions": "./src/lifecycle-functions.ts",
      "./types": "./src/types.ts",
      "./user": "./src/user.ts",
      "./express": "./src/express.ts",
      "./fastify": "./src/fastify.ts",
      "./hono": "./src/hono.ts",
      "./next": "./src/next.ts",
      "./mongoose": "./src/mongoose.ts",
      "./zod": "./src/zod.ts",
      "./trpc": "./src/trpc.ts",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "clean": "rimraf lib dist .tshy .tshy-build .tsbuildinfo coverage doc test-build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tshy",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write \"./{src,test,examples,scripts}/**/*.{ts,js,cjs,mjs}\"",
    "format:check": "prettier --check \"./{src,test,examples,scripts}/**/*.{ts,js,cjs,mjs}\"",
    "check:exports": "attw --pack . --profile node16",
    "smoke": "node scripts/smoke.cjs && node scripts/smoke.mjs",
    "docs:build": "typedoc",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm check:exports && pnpm smoke",
    "prepack": "pnpm clean && pnpm build"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "express": "^5.1.0",
    "fastify": "^5.0.0",
    "hono": "^4.0.0",
    "json-mask": "^2.0.0",
    "mongoose": ">=5 <10",
    "next": ">=14 <17",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "json-mask": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^2.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "hono": "^4.12.23",
    "json-mask": "^2.0.0",
    "mongoose": "^8.24.0",
    "next": "^16.2.6",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tshy": "^4.1.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "prettier": {
    "trailingComma": "es5",
    "singleQuote": true
  },
  "author": "Captain Caius",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/esm/core.d.ts",
        "default": "./dist/esm/core.js"
      },
      "require": {
        "types": "./dist/commonjs/core.d.ts",
        "default": "./dist/commonjs/core.js"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/esm/errors.d.ts",
        "default": "./dist/esm/errors.js"
      },
      "require": {
        "types": "./dist/commonjs/errors.d.ts",
        "default": "./dist/commonjs/errors.js"
      }
    },
    "./http-adapter": {
      "import": {
        "types": "./dist/esm/http-adapter.d.ts",
        "default": "./dist/esm/http-adapter.js"
      },
      "require": {
        "types": "./dist/commonjs/http-adapter.d.ts",
        "default": "./dist/commonjs/http-adapter.js"
      }
    },
    "./lifecycle-functions": {
      "import": {
        "types": "./dist/esm/lifecycle-functions.d.ts",
        "default": "./dist/esm/lifecycle-functions.js"
      },
      "require": {
        "types": "./dist/commonjs/lifecycle-functions.d.ts",
        "default": "./dist/commonjs/lifecycle-functions.js"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/esm/types.d.ts",
        "default": "./dist/esm/types.js"
      },
      "require": {
        "types": "./dist/commonjs/types.d.ts",
        "default": "./dist/commonjs/types.js"
      }
    },
    "./user": {
      "import": {
        "types": "./dist/esm/user.d.ts",
        "default": "./dist/esm/user.js"
      },
      "require": {
        "types": "./dist/commonjs/user.d.ts",
        "default": "./dist/commonjs/user.js"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/esm/express.d.ts",
        "default": "./dist/esm/express.js"
      },
      "require": {
        "types": "./dist/commonjs/express.d.ts",
        "default": "./dist/commonjs/express.js"
      }
    },
    "./fastify": {
      "import": {
        "types": "./dist/esm/fastify.d.ts",
        "default": "./dist/esm/fastify.js"
      },
      "require": {
        "types": "./dist/commonjs/fastify.d.ts",
        "default": "./dist/commonjs/fastify.js"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/esm/hono.d.ts",
        "default": "./dist/esm/hono.js"
      },
      "require": {
        "types": "./dist/commonjs/hono.d.ts",
        "default": "./dist/commonjs/hono.js"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/esm/next.d.ts",
        "default": "./dist/esm/next.js"
      },
      "require": {
        "types": "./dist/commonjs/next.d.ts",
        "default": "./dist/commonjs/next.js"
      }
    },
    "./mongoose": {
      "import": {
        "types": "./dist/esm/mongoose.d.ts",
        "default": "./dist/esm/mongoose.js"
      },
      "require": {
        "types": "./dist/commonjs/mongoose.d.ts",
        "default": "./dist/commonjs/mongoose.js"
      }
    },
    "./zod": {
      "import": {
        "types": "./dist/esm/zod.d.ts",
        "default": "./dist/esm/zod.js"
      },
      "require": {
        "types": "./dist/commonjs/zod.d.ts",
        "default": "./dist/commonjs/zod.js"
      }
    },
    "./trpc": {
      "import": {
        "types": "./dist/esm/trpc.d.ts",
        "default": "./dist/esm/trpc.js"
      },
      "require": {
        "types": "./dist/commonjs/trpc.d.ts",
        "default": "./dist/commonjs/trpc.js"
      }
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "module": "./dist/esm/index.js"
}
